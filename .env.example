# =============================================================================
# Project Delivery Copilot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM (OpenAI-compatible)
# -----------------------------------------------------------------------------
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o
LLM_API_KEY=sk-...

# Optional tuning
LLM_TIMEOUT=120
LLM_MAX_RETRIES=2
# Set to false for models that reject the temperature parameter (e.g. gpt-5, o1, o3, o4)
LLM_TEMPERATURE_SUPPORTED=true

# -----------------------------------------------------------------------------
# Jira (leave blank to run without Jira; dry-run still works)
# -----------------------------------------------------------------------------
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_USER=you@yourcompany.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=PROJ

# Optional
JIRA_TIMEOUT=30
